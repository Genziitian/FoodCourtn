# ════════════════════════════════════════════════════════════════════
# FoodCourt — environment configuration template
# ════════════════════════════════════════════════════════════════════
# Copy this file to `.env` at the repo root, fill in real values, then
# symlink it into each app so Vite picks it up:
#
#   cp .env.example .env
#   ln -sf ../../.env apps/customer/.env
#   ln -sf ../../.env apps/admin/.env
#   ln -sf ../../.env apps/kds/.env
#
# Conventions:
#   - `VITE_*` vars are bundled into the browser. NEVER put secrets here.
#   - Anything else is server-side only (Edge Functions, scripts).
#   - [required] = app won't function without it in production.
#   - [optional] = falls back to mocks/sensible defaults in development.
#
# The customer/admin/KDS apps run end-to-end against in-memory mocks if
# the Supabase keys below are blank — useful for local UI development.
# ════════════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────────────
# 1) SUPABASE — Postgres + Auth + Realtime + Storage + Edge Functions
# ──────────────────────────────────────────────────────────────────────
# Get these from Project Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=                              # [required] https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=                         # [required] publishable / anon key

# Server-side only — bypasses RLS. Used by Edge Functions, migrations,
# and any cron jobs. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=                      # [required for server] sb_secret_xxx
SUPABASE_PROJECT_REF=                           # xxxx prefix in your project URL
SUPABASE_DB_URL=                                # postgres://postgres.xxxx:[pwd]@aws-0-region.pooler.supabase.com:6543/postgres
SUPABASE_JWT_SECRET=                            # used to mint/verify custom claims (customer_id, role)


# ──────────────────────────────────────────────────────────────────────
# 2) APP URLS — cross-linking between the 3 surfaces
# ──────────────────────────────────────────────────────────────────────
VITE_CUSTOMER_URL=http://localhost:5173
VITE_ADMIN_URL=http://localhost:5174
VITE_KDS_URL=http://localhost:5175
VITE_PUBLIC_API_URL=http://localhost:54321      # local supabase, or your edge functions host
WEBHOOK_BASE_URL=https://api.foodcourt.app      # public callback URL for payment gateways


# ──────────────────────────────────────────────────────────────────────
# 3) PAYMENTS — platform-level webhook signing secrets
# ──────────────────────────────────────────────────────────────────────
# Per-restaurant credentials live in the `payment_gateways` table
# (encrypted via Supabase Vault). The values below are platform-level
# secrets used by our central webhook handler to verify signatures, and
# as test-mode fallbacks during development.

# Razorpay — primary gateway for India
RAZORPAY_KEY_ID=                                # rzp_test_xxx in dev, rzp_live_xxx in prod
RAZORPAY_KEY_SECRET=                            # dev fallback only — prod keys live in DB per restaurant
RAZORPAY_WEBHOOK_SECRET=                        # set this in Razorpay dashboard → Webhooks

# Stripe — international cards
STRIPE_SECRET_KEY=                              # sk_test_xxx
STRIPE_WEBHOOK_SECRET=                          # whsec_xxx (from Stripe CLI for local dev)
VITE_STRIPE_PUBLISHABLE_KEY=                    # pk_test_xxx (safe in browser)

# PhonePe
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=UAT                                 # UAT | PROD

# Paytm
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBHOOK_KEY=
PAYTM_ENV=staging                               # staging | production

# Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENV=TEST                               # TEST | PROD


# ──────────────────────────────────────────────────────────────────────
# 4) OTP / SMS — customer phone authentication
# ──────────────────────────────────────────────────────────────────────
# Supabase Auth has phone OTP built in (configure in Auth → Providers).
# These values are only needed if you want a custom provider.

# MSG91 — India-friendly default
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=                              # OTP template ID
MSG91_SENDER_ID=FDCRT
MSG91_ROUTE=4                                   # 4 = transactional

# Twilio — international fallback
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                                    # E.164 format e.g. +15551234567
TWILIO_VERIFY_SERVICE_SID=                      # if using Verify API

# Misc
OTP_TTL_SECONDS=300                             # how long a code stays valid
OTP_MAX_ATTEMPTS=5                              # before blocking the phone for 1h


# ──────────────────────────────────────────────────────────────────────
# 5) PUSH NOTIFICATIONS — order updates, promotions, loyalty
# ──────────────────────────────────────────────────────────────────────
# Web Push (browser Notification API + service worker)
VITE_FCM_VAPID_PUBLIC_KEY=                      # frontend-visible public VAPID key

# Firebase Cloud Messaging — server send side
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=                               # service account email
FCM_PRIVATE_KEY=                                # base64-encoded private key
FCM_SERVER_KEY=                                 # legacy server key (older clients)


# ──────────────────────────────────────────────────────────────────────
# 6) REDIS — BullMQ queues, OTP sessions, realtime fan-out
# ──────────────────────────────────────────────────────────────────────
REDIS_URL=                                      # redis://default:pwd@host:6379
REDIS_TLS=false                                 # true for managed Redis (Upstash, Elasticache)


# ──────────────────────────────────────────────────────────────────────
# 7) EMAIL — receipts, invoices, transactional
# ──────────────────────────────────────────────────────────────────────
RESEND_API_KEY=                                 # https://resend.com (preferred — simpler)
SENDGRID_API_KEY=                               # alternative
FROM_EMAIL=noreply@foodcourt.app
SUPPORT_EMAIL=help@foodcourt.app
RECEIPT_EMAIL_TEMPLATE_ID=                      # template ID in chosen provider


# ──────────────────────────────────────────────────────────────────────
# 8) MAPS & GEOCODING — saved addresses, delivery zones
# ──────────────────────────────────────────────────────────────────────
VITE_MAPS_PROVIDER=google                       # google | mapbox
VITE_GOOGLE_MAPS_API_KEY=                       # restrict to your domains in Google Cloud Console
VITE_MAPBOX_TOKEN=


# ──────────────────────────────────────────────────────────────────────
# 9) STORAGE — food images, invoices, QR PNGs
# ──────────────────────────────────────────────────────────────────────
# Default: Supabase Storage (uses VITE_SUPABASE_URL above, no extra config).
# Override with any S3-compatible storage if needed.
STORAGE_PROVIDER=supabase                       # supabase | s3 | r2
S3_ENDPOINT=                                    # e.g. https://<account>.r2.cloudflarestorage.com
S3_REGION=ap-south-1
S3_BUCKET=foodcourt-uploads
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=                                  # optional CDN prefix (e.g. cdn.foodcourt.app)


# ──────────────────────────────────────────────────────────────────────
# 10) PRINTING — thermal printer bridge (Phase 2)
# ──────────────────────────────────────────────────────────────────────
# Local Electron app on each restaurant terminal that drives the
# ESC/POS printer. Browser-based WebUSB is the MVP fallback.
PRINT_BRIDGE_URL=http://localhost:9100          # local Electron bridge
PRINT_BRIDGE_TOKEN=                             # shared secret per restaurant
PRINT_RETRIES=3
PRINT_RETRY_DELAY_MS=1000


# ──────────────────────────────────────────────────────────────────────
# 11) SECURITY — encryption at rest, JWT signing, rate limits
# ──────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=                                 # 32-byte base64 — encrypts payment_gateways.secret_ref
JWT_SECRET=                                     # for custom-issued tokens (e.g. order short-links)
JWT_ISSUER=foodcourt
JWT_AUDIENCE=foodcourt-api

RATE_LIMIT_REDIS_PREFIX=fc:rl
RATE_LIMIT_OTP_PER_PHONE=5                      # OTP requests per hour per phone
RATE_LIMIT_API_PER_IP=100                       # API calls per minute per IP

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175


# ──────────────────────────────────────────────────────────────────────
# 12) MONITORING — error tracking, product analytics
# ──────────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                                # public, safe in browser
SENTRY_AUTH_TOKEN=                              # for uploading source maps
SENTRY_ENVIRONMENT=development                  # development | staging | production
SENTRY_ORG=
SENTRY_PROJECT=

VITE_POSTHOG_KEY=                               # https://posthog.com
VITE_POSTHOG_HOST=https://app.posthog.com


# ──────────────────────────────────────────────────────────────────────
# 13) PLATFORM DEFAULTS
# ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                            # development | test | staging | production
PORT=3000                                       # for separate API server, if any
LOG_LEVEL=info                                  # debug | info | warn | error

# Visible to the browser — sets default brand identity
VITE_APP_NAME=FoodCourt
VITE_BRAND_PRIMARY=#EA580C
VITE_DEFAULT_LOCALE=en-IN
VITE_DEFAULT_CURRENCY=INR
VITE_DEFAULT_GST_PERCENT=5
VITE_SUPPORT_PHONE=+91 80 0000 0000


# ──────────────────────────────────────────────────────────────────────
# 14) FEATURE FLAGS — staged rollout
# ──────────────────────────────────────────────────────────────────────
VITE_ENABLE_RESERVATIONS=true
VITE_ENABLE_LOYALTY=true
VITE_ENABLE_MULTI_GATEWAY=true
VITE_ENABLE_KDS_REALTIME=true
VITE_ENABLE_PUSH_NOTIFICATIONS=true
VITE_ENABLE_RATINGS=true
VITE_ENABLE_THEME_PER_BRANCH=true


# ──────────────────────────────────────────────────────────────────────
# 15) SUPER ADMIN — bootstrap the first platform admin
# ──────────────────────────────────────────────────────────────────────
# On first deploy, a migration grants this email the `super_admin` role.
SUPER_ADMIN_BOOTSTRAP_EMAIL=
SUPER_ADMIN_BOOTSTRAP_NAME=
