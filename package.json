  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}
