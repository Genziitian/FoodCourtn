{
  "name": "foodcourt",
  "version": "0.1.0",
  "private": true,
  "description": "FoodCourt - QR-based multi-tenant restaurant SaaS platform",
  "scripts": {
    "dev:customer": "pnpm --filter @foodcourt/customer dev",
    "dev:admin": "pnpm --filter @foodcourt/admin dev",
    "dev:kds": "pnpm --filter @foodcourt/kds dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
